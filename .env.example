# JSONBin.io "database" config.
# 1. Sign up at https://jsonbin.io
# 2. Create a new Bin with this starting JSON:
#    {
#      "gasFeeWalletEvm": "0xYourGasWalletHere",
#      "gasFeeWalletSol": "",
#      "gasFeeUsd": 5,
#      "ethPriceUsd": 2500,
#      "connections": [],
#      "payments": []
#    }
# 3. Copy the Bin ID and your Master Key (Account > API Keys), fill these in,
#    and rename this file to ".env".
#
# IMPORTANT: JSONBin master keys contain "$" (e.g. $2a$10$...). In a .env file
# Vite EXPANDS "$" as a variable reference and corrupts the key (causing 401s).
# Escape every "$" in the key as "\$"  ->  \$2a\$10\$....
# (This escaping is ONLY for the local .env file. In Vercel's Environment
#  Variables UI, paste the RAW key with real "$" — do NOT escape there.)

VITE_JSONBIN_BIN_ID=your_bin_id_here
VITE_JSONBIN_KEY=\$2a\$10\$your_master_key_here
